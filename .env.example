# Databricks CLI profile (maps to --profile flag)
DATABRICKS_PROFILE=dev

# HuggingFace model endpoint — Grainger JFrog Artifactory mirror
# Direct huggingface.co downloads are blocked by corporate firewall for large files.
HF_ENDPOINT=https://graingerreadonly.jfrog.io/artifactory/api/huggingfaceml/huggingfaceml-remote

# Databricks workspace base path for data and model artifacts
WORKSPACE_BASE=/Workspace/Users/noel.nosse@grainger.com/visual-model-ft/histology

# DBFS path for wheel deployment
DBFS_WHEEL_DIR=dbfs:/FileStore/wheels
